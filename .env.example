# ─────────────────────────────────────────────────────────────────────────────
# Shopify
# ─────────────────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=your_store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

KLAVIYO_PRIVATE_KEY=your_klaviyo_private_key
MOONSHOT_API_KEY=your_moonshot_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Admin Security
# Used for: POST /admin/jobs/run-recovery (optional manual job trigger guard)
# Leave empty to disable protection (development only).
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_SECRET=your_admin_secret

# ─────────────────────────────────────────────────────────────────────────────
# Evolution API (WhatsApp — self-hosted on VPS)
# Set these once your VPS is configured and Evolution API is installed.
# EVOLUTION_API_URL: Base URL of your Evolution API instance
# EVOLUTION_API_KEY: Global API key (set in Evolution API config)
# EVOLUTION_INSTANCE_NAME: Name of the WhatsApp instance (created via Evolution dashboard)
# ─────────────────────────────────────────────────────────────────────────────
EVOLUTION_API_URL=https://api-evolution.yourdomain.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=your_instance_name

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Recovery Campaign Config
# These values are injected into the recovery message sent to leads.
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_COUPON_CODE=PIRANHA5
WHATSAPP_DISCOUNT_PERCENT=5
WHATSAPP_DISCOUNT_CODE=ORDER10
WHATSAPP_TEMPLATE_WINDOW_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# Dispatch Window (Local Timezone)
# ─────────────────────────────────────────────────────────────────────────────
DISPATCH_TZ=Europe/Lisbon
DISPATCH_START_HOUR=9
DISPATCH_END_HOUR=18
DISPATCH_MIN_DELAY_SEC=15
DISPATCH_MAX_DELAY_SEC=45
PRESENCE_MIN_MS=1000
PRESENCE_MAX_MS=3000
